        "/v1/txn/logs": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Retrieve EVM event logs with flexible filtering by chain, address, block range, time range, topic signature, etc.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Transaction"
                ],
                "summary": "Query event logs",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Chain ID",
                        "name": "chain_id",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Contract address (hex)",
                        "name": "address",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Transaction hash",
                        "name": "tx_hash",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Block number range start",
                        "name": "bn_start",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Block number range end",
                        "name": "bn_end",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Event signature (32-byte hex, e.g. 0x...)",
                        "name": "signature",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "From address or 32-byte hex topic",
                        "name": "from",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "To address or 32-byte hex topic",
                        "name": "to",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Start time (RFC3339 format)",
                        "name": "start_time",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "End time (RFC3339 format)",
                        "name": "end_time",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Order by field (default: 2 = block_number)",
                        "name": "order_by",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "Descending order",
                        "name": "desc",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Page number (min: 1)",
                        "name": "page",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Page size (min: 1, max: 100)",
                        "name": "size",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/protocol.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "result": {
                                            "$ref": "#/definitions/contracts.GetLogRes"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/protocol.Response"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/protocol.Response"
                        }
                    }
                }
            }
        },
